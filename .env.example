# ===== Neon Postgres =====
# Récupéré sur https://console.neon.tech (chaîne "pooled")
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ===== Auth.js (admin) =====
# Générer avec : npx auth secret  OU  openssl rand -base64 32
AUTH_SECRET="changez-moi-en-une-cle-aleatoire-longue"
# Identifiants admin (login simple email/password). Hash bcrypt.
# Générer le hash avec : node -e "console.log(require('bcryptjs').hashSync('VotreMotDePasse', 10))"
ADMIN_EMAIL="admin@automoveazur.fr"
ADMIN_PASSWORD_HASH="$2a$10$..."

# ===== Instagram Graph API =====
# Voir : https://developers.facebook.com/docs/instagram-platform/instagram-graph-api
IG_USER_ID="17841400000000000"
IG_ACCESS_TOKEN="EAAG..."
# Secret pour sécuriser les routes cron
CRON_SECRET="changez-moi"

# ===== Resend (emails de confirmation RDV) =====
RESEND_API_KEY="re_..."
RESEND_FROM="Auto Move Azur <noreply@automoveazur.fr>"
ADMIN_NOTIFICATION_EMAIL="contact@automoveazur.fr"

# ===== Coordonnées affichées =====
